window.THREAD = {    "thread_data": [],    "thread_id": 51586,    "thread_page": 1,    "thread_pages": 1,    "forum_type": "mn",    "forum_id": 33,    "thread_up_link_desc": "forum_mn33.html#thread_51586",    "thread_up_link_asc": "forum_mn33_pa_71.html#thread_51586",    "forum_title": "۞ موسوعة بيانات الإمام المهدي المنتظر ۞",    "thread_title": "عِتابٌ شَديد اللهجَة للأنصار السَّابقين الأخيار فأُحرِجَكُم على العام وأقول: فانتقوا البيانات المُبَشِّرة وليست المُنَفِّرَة من بعد ما تبيَّن لصناع القرار أنَّه الحقّ؛ فلا تستفزوهم ببيانات غَضَب الإمام المهديّ ناصِر مُحَمَّد اليمانيّ بسبب إعراضهم عن الدَّعوة المهديَّة عشرين سَنةً فتأخذهم العزَّة بالإثم؛ فَلِكُلِّ حالٍ مَقال، فاسعوا لوحدة صَفِّ قادتكم ووحدة شعوبكم ودواء جراح أُمَّتكم لنسيان ماضيهم الأليم بالعفو والمُصافحة والمُسامحة مِن شان الله وهو خَير الغافرين والكاظِمين الغَيْظ والعافين عَنِّ الناس والله يُحِب المُحسنين، والتَّذكير بالعَدوِّ الحَقيقيّ، أم تُريدون من الإمام المِهديّ كتابة بَيانٍ جَديدٍ حين تتبيَّن الأحداث؟ ولَكنّي لَستُ صحفيًّا إعلاميًّا يكتب حِين الحَدَث! بل نُفَصِّل الأحداث مِن قَبْل الحدَث تَفصيلًا، ونأمُركم وكافَّة المُسلمين لِرَبِّ العالَمين بِنَشر البَيان على الرَّابِط التالي واحرِصوا على تاريخه يَوم تنزيله ..",    "imamposts": [{"postid":"470343","page":1,"postcount":1}],    "postcounts": {"470343":1}};/* keep push exactly as before */window.__pushPost = function(o){    window.THREAD.thread_data.push(o);};loadSeq([ver("js_json/posts/post_470343.js"),ver(base + "Assets/loader.js")],0);